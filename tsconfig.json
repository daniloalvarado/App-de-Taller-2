{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "sanity/sanity.types.ts"
  ],
  "exclude": [
    "node_modules",
    "TeamSync",
    "admin-web",
    "sanity"
  ]
}
